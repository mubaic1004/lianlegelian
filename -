<title>胖皮厨房</title>
<style>
/* 「连了个连」 —— 黏土拟物可爱风 */
* { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
html, body { height: 100%; }
/* 阿里妈妈方圆体(wght700 + 最圆切角,按游戏用字子集化,77KB)—— 胖、圆、笔画简洁 */
@font-face {
  font-family: 'FangYuan';
  src: url(data:font/woff2;base64,) format('woff2');
  font-display: swap;
}
:root {
  --font-fun: 'FangYuan', 'Yuanti SC', 'YouYuan', '幼圆', 'PingFang SC', 'Microsoft YaHei', ui-rounded, sans-serif;
}
body {
  /* 正文/说明小字:清晰的系统圆体 */
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', ui-rounded, system-ui, sans-serif;
  /* 奶油黄→樱花粉→薄荷绿,叠白色波点 —— 参考肥鹅健身房的暖调卡通背景 */
  background:
    radial-gradient(rgba(255, 255, 255, .4) 13%, transparent 14%) 0 0 / 48px 48px,
    radial-gradient(rgba(255, 255, 255, .4) 13%, transparent 14%) 24px 24px / 48px 48px,
    linear-gradient(165deg, #FFE9AE 0%, #FFD9E4 52%, #C9F0DE 100%);
  color: #453B34;
  overflow: hidden;
  user-select: none;
  -webkit-user-select: none;
}
body.in-game {
  background: linear-gradient(160deg, #FFF4DC 0%, #FFE9F1 55%, #E7F8EF 100%);
}
#bg-deco { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
.deco { position: absolute; opacity: .55; animation: decoFloat ease-in-out infinite alternate; filter: drop-shadow(0 4px 6px rgba(180, 110, 60, .15)); }
body.in-game .deco { display: none; }
@keyframes decoFloat { to { transform: translateY(-20px) rotate(7deg); } }
#app { position: relative; z-index: 1; height: 100dvh; max-width: 480px; margin: 0 auto; display: flex; flex-direction: column; }
.screen { flex: 1; display: flex; flex-direction: column; min-height: 0; }
button { font-family: inherit; }

.clay {
  background: rgba(255, 255, 255, .88);
  border: 3px solid #fff;
  border-radius: 22px;
  box-shadow: 0 8px 20px rgba(236, 72, 153, .10), 0 4px 0 rgba(236, 72, 153, .08), inset 0 2px 6px rgba(255, 255, 255, .9);
}

/* ———— 首页 ———— */
.home { align-items: center; justify-content: flex-start; gap: 10px; padding: 18px 20px; overflow-y: auto; }
.title-wrap { text-align: center; }
.mascot { font-size: 52px; animation: floaty 2.4s ease-in-out infinite; }
/* POP MART 式标题:胖圆字 + 加宽字形 + 双层错位色块阴影(薄荷托底、玫红投影),贴纸感 */
.title-art { position: relative; display: inline-block; padding: 14px 16px 18px; }
.home h1 {
  font-size: 50px;
  color: #FF9FBC; /* 蜜桃粉,和奶油粉背景同族 */
  letter-spacing: 6px;
  text-shadow:
    -2px -2px 0 #FFFDF4, -3px 3px 0 #FFFDF4,   /* 奶油白托底(左上) */
    4px 4px 0 #EA6390, 5px 6px 0 #EA6390,       /* 深一号玫瑰投影(右下) */
    7px 9px 12px rgba(234, 99, 144, .28);
}
.hang { position: absolute; font-size: 24px; pointer-events: none; z-index: 2; animation: hangSway 2.8s ease-in-out infinite alternate; filter: drop-shadow(0 3px 4px rgba(200, 60, 110, .3)); }
.hang-berry { top: -10px; left: 4%; transform: rotate(-18deg); }
.hang-ice { top: -14px; right: 3%; font-size: 27px; transform: rotate(15deg); animation-delay: -1.4s; }
@keyframes hangSway { to { transform: rotate(8deg) translateY(-4px); } }
.tagline { font-size: 12.5px; color: #9A9088; font-weight: 600; margin-top: 5px; }
.rules { padding: 11px 14px; font-size: 12px; line-height: 1.75; color: #6E655D; width: 100%; }
.rules b { color: #DB2777; }
.lv-card { display: flex; align-items: center; gap: 12px; padding: 11px 14px; width: 100%; flex-shrink: 0; cursor: pointer; text-align: left; transition: transform .15s ease-out; }
.lv-card:hover { transform: translateY(-2px); }
.lv-card:active { transform: translateY(2px); }
.lv-card.locked { filter: grayscale(.65) opacity(.8); }
.lv-emoji { font-size: 28px; }
.lv-info { flex: 1; display: flex; flex-direction: column; gap: 2px; }
.lv-info b { font-size: 15.5px; color: #3E3630; }
.lv-info small { font-size: 11.5px; color: #9C948B; }
.lv-rate { font-size: 11px; font-weight: 800; border-radius: 999px; padding: 5px 10px; white-space: nowrap; }
.lv-rate.easy { background: #D1FAE5; color: #059669; }
.lv-rate.mid { background: #FEF3C7; color: #B45309; }
.lv-rate.hard { background: #FFE4E6; color: #E11D48; }
.foot { font-size: 10.5px; color: #B3A89E; text-align: center; }

/* ———— 主菜单 ———— */
.home.menu { justify-content: center; gap: 12px; overflow-y: visible; }
.menu-btn { width: 100%; display: flex; align-items: center; gap: 14px; padding: 17px 24px; font-size: 19px; font-weight: 800; color: #3E3630; cursor: pointer; transition: transform .15s ease-out; }
.menu-btn:hover { transform: translateY(-2px); }
.menu-btn:active { transform: translateY(2px); }
.menu-btn .mi { font-size: 27px; }
.topbar.bare { width: calc(100% + 8px); padding: 0 0 6px; }
.icon-spacer { width: 40px; }
.credits { line-height: 1.9; }
.credits small { font-size: 10px; }

/* ———— 设置页 ———— */
.set-card { width: 100%; padding: 20px 18px; display: flex; flex-direction: column; gap: 20px; }
.set-row { display: flex; align-items: center; gap: 10px; font-weight: 800; color: #3E3630; font-size: 14.5px; }
.set-row label { min-width: 46px; }
.set-ic { font-size: 20px; }
.set-row input[type="range"] { flex: 1; accent-color: #EC4899; height: 22px; cursor: pointer; }
.seg { display: flex; gap: 6px; margin-left: auto; }
.seg button { border: 2px solid #FBCFE8; background: #fff; color: #B457A0; border-radius: 999px; padding: 6px 13px; font-size: 12.5px; font-weight: 800; cursor: pointer; }
.seg button.on { background: linear-gradient(180deg, #F9A8D4, #EC4899); border-color: #EC4899; color: #fff; box-shadow: 0 3px 0 #C0347C; }

/* ———— 玩法教学(聚光灯引导) ———— */
.guide { position: relative; }
.g-demo { flex: 1; display: flex; flex-direction: column; gap: 16px; padding: 18px 14px; max-width: 400px; margin: 0 auto; width: 100%; justify-content: center; pointer-events: none; filter: grayscale(.9) brightness(.82) saturate(.5); }
.g-tiles { display: flex; gap: 9px; justify-content: center; align-items: center; flex-wrap: wrap; padding: 6px 0; }
.d-tile { width: 46px; height: 46px; border-radius: 13px; display: inline-grid; place-items: center; font-size: 26px; border: 2px solid rgba(255, 255, 255, .95); box-shadow: 0 3px 0 rgba(190, 110, 160, .35), 0 5px 10px rgba(180, 120, 170, .18); }
.d-tile.covered { filter: saturate(.35) brightness(.6); }
.d-gap { width: 6px; }
.g-recipe { padding: 6px 12px; max-width: 300px; margin: 0 auto; }
.g-recipe .rb-row { font-size: 21px; padding: 4px; }
.g-mask { position: fixed; inset: 0; z-index: 2000; background: rgba(70, 35, 70, .45); backdrop-filter: grayscale(1) brightness(.62); animation: fadeIn .3s; }
.g-spot { z-index: 2100 !important; animation: spotPulse 1.6s ease-in-out infinite; border-radius: 18px; box-shadow: 0 0 0 4px #fff, 0 0 44px rgba(255, 240, 250, .8); background: #FFF6FB; pointer-events: none; }
@keyframes spotPulse { 0%, 100% { transform: scale(var(--gs, 1.12)); } 50% { transform: scale(calc(var(--gs, 1.12) + .05)); } }
.g-caption { position: fixed; left: 50%; transform: translateX(-50%); z-index: 2200; width: min(86vw, 340px); text-align: center; padding: 16px 14px 14px; animation: riseIn .3s ease-out; background: linear-gradient(180deg, #FFFEFE, #FFF3F9); }
.g-art { font-size: 34px; letter-spacing: 3px; margin-bottom: 8px; display: flex; align-items: center; justify-content: center; gap: 7px; }
.g-art i { font-style: normal; font-size: 17px; color: #C9A8D4; font-weight: 800; }
.ga-gold { filter: drop-shadow(0 0 6px #FCD34D); }
.ga-green { filter: drop-shadow(0 0 6px #34D399); }
.ga-rot { position: relative; display: inline-grid; place-items: center; }
.ga-bar { position: absolute; bottom: -3px; left: 10%; height: 4px; border-radius: 2px; background: #6EE7B7; animation: gaRot 2.2s linear infinite; }
@keyframes gaRot { 0% { width: 80%; background: #6EE7B7; } 55% { background: #FCD34D; } 100% { width: 4%; background: #FB7185; } }
.g-text { font-size: 13.5px; font-weight: 700; color: #6E655D; line-height: 1.6; }
.g-nav { position: fixed; bottom: max(18px, env(safe-area-inset-bottom)); left: 50%; transform: translateX(-50%); z-index: 2300; display: flex; align-items: center; gap: 14px; }
.g-btn { border: 3px solid #fff; background: rgba(255, 255, 255, .95); color: #B457A0; border-radius: 999px; padding: 10px 22px; font-size: 16px; font-weight: 800; cursor: pointer; box-shadow: 0 4px 0 #F3C4DC; }
.g-btn.primary { background: linear-gradient(180deg, #F9A8D4, #EC4899); color: #fff; border-color: #F9A8D4; box-shadow: 0 4px 0 #C0347C; }
.g-btn:active:not(:disabled) { transform: translateY(2px); }
.g-btn:disabled { opacity: .4; cursor: default; }
.g-dots { display: flex; gap: 7px; }
.g-dots i { width: 8px; height: 8px; border-radius: 999px; background: #E9D5F0; transition: all .2s; }
.g-dots i.on { width: 22px; background: #EC4899; }
.g-skip { position: fixed; top: 14px; right: 14px; z-index: 2300; border: 2px solid rgba(255, 255, 255, .8); background: rgba(255, 255, 255, .75); color: #B457A0; border-radius: 999px; padding: 7px 15px; font-size: 12.5px; font-weight: 800; cursor: pointer; }

/* ———— 对局页 ———— */
.topbar { display: flex; align-items: center; gap: 8px; padding: 10px 14px 2px; }
.lv-name { flex: 1; text-align: center; font-weight: 800; font-size: 15px; color: #3E3630; }
.icon-btn { width: 40px; height: 40px; border: 3px solid #fff; border-radius: 14px; background: rgba(255,255,255,.9); cursor: pointer; display: grid; place-items: center; color: #B457A0; box-shadow: 0 3px 0 #F3C4DC; }
.icon-btn:active { transform: translateY(2px); box-shadow: 0 1px 0 #F3C4DC; }
.icon-btn svg { width: 20px; height: 20px; }

.progress { margin: 8px 16px 2px; height: 15px; background: #fff; border-radius: 999px; position: relative; box-shadow: inset 0 2px 5px rgba(150, 80, 120, .18); }
.progress-fill { height: 100%; width: 0; border-radius: 999px; background: linear-gradient(90deg, #F9A8D4, #F472B6); transition: width .35s ease-out; }
.progress-num { position: absolute; right: 9px; top: 50%; transform: translateY(-50%); font-size: 10px; font-weight: 800; color: #BE185D; }

.orderbar { display: flex; align-items: center; gap: 6px; margin: 6px 14px 0; min-height: 32px; background: rgba(255,255,255,.6); border-radius: 14px; padding: 4px 8px; }
.ob-label { font-size: 10.5px; font-weight: 800; color: #B45309; white-space: nowrap; }
.ob-list { display: flex; gap: 5px; overflow-x: auto; flex: 1; scrollbar-width: none; }
.ob-list::-webkit-scrollbar { display: none; }
.ob-chip { display: inline-flex; align-items: center; gap: 2px; background: #fff; border: 2px solid #FBCFE8; border-radius: 999px; padding: 2px 8px; font-size: 13px; white-space: nowrap; box-shadow: 0 2px 0 rgba(236, 72, 153, .12); cursor: pointer; }
.ob-chip:active { transform: translateY(1px); }
.ob-chip b { font-size: 10px; color: #BE185D; }
.ob-chip.done { border-color: #6EE7B7; background: #ECFDF5; }
.ob-chip.done b { color: #059669; }
.ob-chip.done::after { content: '✓'; font-size: 10px; color: #059669; font-weight: 800; }
.ob-dishes { font-size: 10.5px; font-weight: 800; color: #A78BB5; white-space: nowrap; }
.ghost-dish { position: fixed; z-index: 992; font-size: 32px; pointer-events: none; transition: transform .42s cubic-bezier(.4, .9, .4, 1), opacity .42s; filter: drop-shadow(0 4px 8px rgba(180, 83, 9, .4)); }

.board-wrap { flex: 1; min-height: 0; display: flex; align-items: center; justify-content: center; padding: 4px; }
.board { position: relative; }
.linksvg { position: absolute; inset: 0; z-index: 900; pointer-events: none; overflow: visible; }
.linkline { fill: none; stroke: #F472B6; stroke-width: 6; stroke-linecap: round; stroke-linejoin: round; stroke-dasharray: 9 7; filter: drop-shadow(0 2px 3px rgba(236, 72, 153, .45)); animation: dash .4s linear; }
.linkline.recipe { stroke: #34D399; filter: drop-shadow(0 2px 3px rgba(16, 185, 129, .5)); }
@keyframes dash { from { stroke-dashoffset: 64; opacity: .4; } to { stroke-dashoffset: 0; opacity: 1; } }

.tile {
  position: absolute; padding: 0; cursor: pointer;
  border: 2px solid rgba(255, 255, 255, .95); border-radius: 24%;
  display: grid; place-items: center;
  box-shadow: 0 3px 0 rgba(190, 110, 160, .35), 0 5px 10px rgba(180, 120, 170, .18), inset 0 1px 3px rgba(255, 255, 255, .9);
  transition: transform .15s ease-out, filter .2s;
  touch-action: manipulation;
}
.tile .face { line-height: 1; pointer-events: none; filter: drop-shadow(0 1px 1px rgba(0, 0, 0, .08)); }
.tile.covered { filter: saturate(.35) brightness(.6); box-shadow: 0 1px 0 rgba(120, 90, 120, .3); cursor: default; }
.tile:not(.covered):hover { transform: translateY(-2px); }
.tile:not(.covered):active { transform: translateY(1px) scale(.97); }
.tile.sel { transform: translateY(-4px) scale(1.1); z-index: 880 !important; box-shadow: 0 0 0 3px #F472B6, 0 8px 16px rgba(236, 72, 153, .35); animation: selBounce .45s ease-out; }
.tile.glow { animation: glowPulse .9s ease-in-out infinite; box-shadow: 0 0 0 3px #FCD34D, 0 4px 12px rgba(245, 158, 11, .55); }
.tile.glow2 { animation: glowPulse .9s ease-in-out infinite; box-shadow: 0 0 0 3px #34D399, 0 4px 12px rgba(16, 185, 129, .55); }
.tile.zap { animation: zapPop .38s ease-out forwards; z-index: 890 !important; }
@keyframes zapPop { 40% { transform: scale(1.28); opacity: 1; } 100% { transform: scale(.1) rotate(24deg); opacity: 0; } }
@keyframes glowPulse { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-3px) scale(1.05); } }
@keyframes selBounce { 0% { transform: scale(.8); } 60% { transform: translateY(-7px) scale(1.16); } 100% { transform: translateY(-4px) scale(1.1); } }
.wobble { animation: wobble .4s; }
@keyframes wobble { 25% { transform: translateX(-4px) rotate(-3deg); } 75% { transform: translateX(4px) rotate(3deg); } }
.shake { animation: shakeB .5s; }
@keyframes shakeB { 25% { transform: rotate(1.4deg); } 75% { transform: rotate(-1.4deg); } }

.tools { display: flex; gap: 10px; justify-content: center; padding: 8px 12px 2px; }
.tool { position: relative; display: flex; flex-direction: column; align-items: center; gap: 3px; padding: 8px 18px; border: 3px solid #fff; cursor: pointer; border-radius: 16px; background: rgba(255,255,255,.92); box-shadow: 0 4px 0 #F3C4DC, 0 6px 12px rgba(236, 72, 153, .12); font-size: 11px; font-weight: 800; color: #4A443E; }
.tool svg { width: 20px; height: 20px; }
.tool:active:not(:disabled) { transform: translateY(3px); box-shadow: 0 1px 0 #F3C4DC; }
.tool:disabled { opacity: .38; cursor: default; }
.tool .badge { position: absolute; top: -7px; right: -5px; font-style: normal; background: #F472B6; color: #fff; font-size: 10px; border-radius: 999px; padding: 1px 6px; box-shadow: 0 2px 4px rgba(0, 0, 0, .15); }

.slotbar { display: flex; gap: 6px; justify-content: center; margin: 10px auto max(14px, env(safe-area-inset-bottom)); padding: 10px; }
.slot-cell { width: 44px; height: 44px; border-radius: 13px; background: #F7E8F2; box-shadow: inset 0 3px 6px rgba(150, 80, 120, .18); display: grid; place-items: center; }
.slot-tile { position: relative; overflow: hidden; width: 40px; height: 40px; border-radius: 11px; display: grid; place-items: center; font-size: 23px; box-shadow: 0 2px 0 rgba(190, 110, 160, .3); animation: dropIn .18s ease-out; }
.slot-tile .fresh { position: absolute; left: 3px; bottom: 2px; height: 3px; border-radius: 2px; max-width: calc(100% - 6px); transition: width .25s; }
.slot-tile.rotting { animation: rotPulse .7s infinite; }
@keyframes rotPulse { 50% { filter: saturate(1.5) hue-rotate(-24deg); transform: scale(.93); } }
@keyframes dropIn { from { transform: scale(1.35); } }
.slotbar.danger .slot-cell { animation: dangerPulse .8s infinite; }
@keyframes dangerPulse { 50% { background: #FFD5DC; box-shadow: inset 0 3px 6px rgba(220, 38, 38, .32); } }

.ghost-tile { position: fixed; z-index: 990; border-radius: 24%; display: grid; place-items: center; transition: transform .28s cubic-bezier(.45, 1.4, .4, 1); box-shadow: 0 6px 14px rgba(236, 72, 153, .3); pointer-events: none; }

.hintbar { position: fixed; left: 50%; bottom: 118px; transform: translateX(-50%); width: max-content; max-width: 82vw; z-index: 950; background: #fff; border: 3px solid #FBCFE8; color: #BE185D; font-size: 13px; font-weight: 600; line-height: 1.5; padding: 10px 16px; border-radius: 18px; box-shadow: 0 8px 18px rgba(236, 72, 153, .22); animation: riseIn .25s ease-out; }
@keyframes riseIn { from { opacity: 0; transform: translate(-50%, 8px); } }

.star { position: fixed; z-index: 995; pointer-events: none; font-size: 15px; animation: burst .55s ease-out forwards; }
@keyframes burst { to { transform: translate(var(--dx), var(--dy)) scale(.3) rotate(60deg); opacity: 0; } }

.modal-overlay { position: fixed; inset: 0; z-index: 1000; background: rgba(90, 40, 80, .5); backdrop-filter: blur(6px); display: grid; place-items: center; animation: fadeIn .25s; }
.modal { width: min(84vw, 340px); text-align: center; padding: 26px 22px 22px; background: linear-gradient(180deg, #FFFEFE, #FFF3F9); }
.modal-overlay .modal { animation: popIn .32s cubic-bezier(.4, 1.6, .5, 1); }
.m-mascot { font-size: 58px; }
.modal h2 { color: #EC4899; margin: 8px 0 4px; font-size: 24px; }
.m-line { font-size: 13px; color: #776C61; font-weight: 600; margin-bottom: 4px; }
.m-stats { font-size: 12px; color: #A78BB5; margin-bottom: 14px; }
.m-btn { display: block; width: 100%; margin-top: 10px; padding: 13px; border: none; border-radius: 16px; cursor: pointer; font-size: 15px; font-weight: 800; }
.m-btn.primary { background: linear-gradient(180deg, #F9A8D4, #EC4899); color: #fff; box-shadow: 0 5px 0 #C0347C, 0 8px 14px rgba(236, 72, 153, .3); }
.m-btn.primary:active { transform: translateY(3px); box-shadow: 0 2px 0 #C0347C; }
.m-btn.plain { background: #fff; color: #B457A0; box-shadow: 0 4px 0 #F3C4DC; }
.m-btn.plain:active { transform: translateY(2px); box-shadow: 0 1px 0 #F3C4DC; }
@keyframes popIn { from { transform: scale(.7); opacity: 0; } }
@keyframes fadeIn { from { opacity: 0; } }

.recipe-book { max-height: 78vh; overflow-y: auto; }
.rb-row { display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 26px; padding: 7px 4px; border-radius: 14px; }
.rb-row i { font-style: normal; font-size: 15px; color: #C9A8D4; font-weight: 800; }
.rb-row small { font-size: 12px; color: #776C61; font-weight: 700; margin-left: 4px; white-space: nowrap; }
.rb-row.hl { background: #ECFDF5; box-shadow: inset 0 0 0 2px #6EE7B7; }
.rb-green { color: #059669; }

.confetti { position: fixed; top: -16px; z-index: 1100; width: 10px; height: 14px; border-radius: 3px; pointer-events: none; animation-name: confFall; animation-timing-function: linear; animation-fill-mode: forwards; }
@keyframes confFall { to { transform: translateY(112vh) rotate(720deg); } }
@keyframes floaty { 50% { transform: translateY(-8px); } }

/* 艺术字应用面:仅用于短的展示性文字(标题/按钮/标签/关卡名);
   整句说明(提示条/规则/教学文案/弹窗描述)保持清晰系统字体以保可读 */
h1, h2, .menu-btn, .lv-name, .lv-info b, .lv-rate, .m-btn, .g-btn, .g-skip,
.tool span, .seg button, .ob-label, .ob-chip, .progress-num, .progress-time,
.tagline, .g-art i, .set-row label, .dish-label, .lv-info small, .foot {
  font-family: var(--font-fun);
}
/* 圆体本身已足够可爱,只给大标题一点点描边增重,其余保持字体原细度以清晰 */
h2 { -webkit-text-stroke: .3px currentColor; paint-order: stroke fill; }
.menu-btn, h2, .lv-name { letter-spacing: 1px; }

.progress-time { position: absolute; left: 9px; top: 50%; transform: translateY(-50%); font-size: 10px; color: #BE185D; }
.progress-time.urgent { color: #DC2626; animation: urgentBlink .6s infinite; }
@keyframes urgentBlink { 50% { opacity: .35; } }

button:focus-visible { outline: 3px solid #F472B6; outline-offset: 2px; }

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: .01s !important; transition-duration: .01s !important; }
}

/* ═══════════ v2.0.0.0 胖皮厨房:美术接入 ═══════════ */
/* —— 主界面:整幅手绘图当背景 + 透明可点区域 —— */
.home-art { position: relative; height: 100dvh; width: 100%;
  background: url(data:image/jpeg;base64,) no-repeat center top / cover; }
